SOLUTION 0  CaCl2
   # Inflow at boundary
        units            mmol/kgw
        temp             25.0
        pH               7.0     charge
        pe               12.5    O2(g)   -0.68
        Ca               0.6
        Cl               1.2
        Tracer           0.5
        Orgc 0
SOLUTION 1
    # Initial solution
        units            mmol/kgw
        temp             25.0
        pH               7.0     charge
        pe               12.5    O2(g)   -0.68
        Na               1.0
        K                0.2
        N(5)             1.2
        Tracer           2.0
        Orgc 0
END
EXCHANGE 1
    X 0.0011
    -equilibrate 1
END

KINETICS 1
Orgc_im
-m 1e-3
-parms 5e-8
-formula Orgc 1
END

SELECTED_OUTPUT 1
        -file            advect.sel
        -reset           false
USER_PUNCH 1
-heading  CELL_NO TIME Orgc_im Orgc 
-start
  10 PUNCH CELL_NO TOTAL_TIME kin("Orgc_im") 
  20 PUNCH tot("Orgc")
-end

