SOLUTION 0 # [K,I,J] = 1,1,1
	units mol/L
	density		1.00  calculate
	water 1.0
	temp 2.500000e+001
	pH 6.770000e+000  # comp 21
	pe 1.385000e+001  # comp 22
	Benz 0.000000e+000 # comp 1
	Tolu 0.000000e+000 # comp 2
	O(0) 5.000000e-004  # comp 5
	Ca 4.209000e-003  # comp 6
